# .env.example - exemplo de variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores reais antes de subir a stack.
# NÃO commite o arquivo `.env` com valores reais.

# InfluxDB inicialização
INFLUX_INIT_MODE=setup
INFLUX_INIT_USERNAME=setta
INFLUX_INIT_PASSWORD=change_me_influx_init_password
INFLUX_INIT_ORG=setta
INFLUX_INIT_BUCKET=pgswifi
INFLUX_INIT_ADMIN_TOKEN=change_me_admin_token

# Tokens/credenciais específicas
INFLUX_TELEGRAF_USERNAME=telegraf
INFLUX_TELEGRAF_PASSWORD=change_me_telegraf_password
INFLUX_TELEGRAF_TOKEN=change_me_telegraf_token

INFLUX_GRAFANA_USERNAME=grafana
INFLUX_GRAFANA_PASSWORD=change_me_grafana_password
INFLUX_GRAFANA_TOKEN=change_me_grafana_token

# Telegraf (MQTT)
TELEGRAF_MQTT_USERNAME=telegraf
TELEGRAF_MQTT_PASSWORD=change_me_mqtt_password

# Mosquitto - caminho do arquivo pwfile (opcional: para quem preferir gerar localmente)
MOSQUITTO_PWFILE=./configs/mosquitto.passwd

# Observações:
# - Substitua os valores "change_me_*" por tokens/senhas seguros.
# - Não suba o `.env` ao GitHub. Mantenha-o privado no servidor de destino.
# - Para produção, considere usar Docker Secrets ou um gerenciador de segredos.
